generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AIProvider {
  id           String    @id
  name         String    @unique
  apiKey       String?
  apiEndpoint  String?
  isActive     Boolean   @default(true)
  requestCount Int       @default(0)
  lastUsed     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
}

model AnalyticsSnapshot {
  id               String   @id
  date             String   @unique
  totalArticles    Int      @default(0)
  analyzedArticles Int      @default(0)
  avgBiasScore     Float?
  leftCount        Int      @default(0)
  centerCount      Int      @default(0)
  rightCount       Int      @default(0)
  topSources       String?
  topThemes        String?
  createdAt        DateTime @default(now())
}

model Article {
  id                    String   @id
  title                 String
  url                   String
  source                String
  publishedAt           DateTime
  category              String?
  spectrumScore         Float?
  popularityScore       String?
  thumbnail             String?
  theme                 String?
  themes                String?
  author                String?
  authorLeanScore       Float?
  leftWingSummary       String?
  leftWingPoints        String?
  rightWingSummary      String?
  rightWingPoints       String?
  socialistSummary      String?
  socialistPoints       String?
  spectrumJustification String?
  wasEdited             Boolean  @default(false)
  editReasoning         String?
  outletBias            Float?
  articleDelta          Float?
  evidence              String?
  tags                  String?
  confidence            Float?
  analysisMethod        String?
  aiProvider            String?
  isArchived            Boolean  @default(false)
  fullContent           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime

  @@index([theme])
  @@index([author])
  @@index([spectrumScore])
  @@index([publishedAt])
  @@index([category])
  @@index([source])
  @@index([isArchived])
}

model AuthorHistory {
  id           String   @id
  name         String
  outlet       String?
  articleTitle String
  articleUrl   String
  leanScore    Float?
  theme        String?
  publishedAt  DateTime
  createdAt    DateTime @default(now())

  @@index([outlet])
  @@index([name])
}

model RequestLog {
  id           String   @id
  provider     String
  requestType  String
  success      Boolean
  errorMessage String?
  duration     Int?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
}
